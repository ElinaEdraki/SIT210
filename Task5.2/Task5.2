import tkinter as tk
from gpiozero import PWMLED, LED

living_room = PWMLED(18)
bathroom = LED(27)
closet = LED(22)

def update_leds():
    living_room.value = 0
    bathroom.off()
    closet.off()
    
    selection = room_var.get()
    if selection == 1:
        living_room.value = brightness_var.get()
    elif selection == 2:
        bathroom.on()
    elif selection == 3:
        closet.on()
def update_brightness(val):
    if room_var.get() == 1:
        living_room.value = brightness_var.get()

def exit_app():
    living_room.value = 0
    bathroom.off()
    closet.off()
    root.destroy()

